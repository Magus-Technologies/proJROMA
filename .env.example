APP_NAME="ProjRoma Facturación"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://projroma.com
APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── BASE DE DATOS ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=magusqao_titanic
DB_USERNAME=magusqao_maguado
DB_PASSWORD=TU_NUEVA_CLAVE_SEGURA_AQUI

# ── CACHÉ / SESIÓN ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# ── CORREO SMTP ────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=matrixsistem.com
MAIL_PORT=465
MAIL_USERNAME=informes@matrixsistem.com
MAIL_PASSWORD=TU_CLAVE_SMTP_AQUI
MAIL_FROM_ADDRESS="informes@projroma.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── SUNAT ──────────────────────────────────────────────────────────────
SUNAT_ENV=production
SUNAT_URL_GEN_XML=http://genxml.des

# ── SEGURIDAD ──────────────────────────────────────────────────────────
ENCRYPT_KEY=

# ── RATE LIMITING ──────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_SECONDS=60
